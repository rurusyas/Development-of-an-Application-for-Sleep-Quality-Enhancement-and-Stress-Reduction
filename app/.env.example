# URL backend Orca. ОБЯЗАТЕЛЬНО задать перед сборкой Capacitor — иначе
# на устройстве/симуляторе iOS чат и leaderboard не достучатся до сервера
# (по умолчанию используется http://localhost:8000, который не виден из
# Capacitor WebView, плюс iOS ATS блокирует http://).
#
# Скопируй этот файл в .env.production (или просто .env) и подставь URL Railway:
#
#   cp .env.example .env.production
#   # отредактируй VITE_API_BASE ниже
#   npm run build
#   npx cap sync ios
#
VITE_API_BASE=https://YOUR-BACKEND.up.railway.app
